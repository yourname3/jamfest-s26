class Sounds {
    let paper_sfx = [
        load_sound("sound/paper1.wav"),
        load_sound("sound/paper2.wav"),
        load_sound("sound/paper3.wav"),
        load_sound("sound/paper4.wav"),
        load_sound("sound/paper5.wav"),
        load_sound("sound/paper6.wav"),
        load_sound("sound/paper7.wav"),
        load_sound("sound/paper8.wav"),
    ];

    let pop = load_sound("sound/pop.wav");
    let poof = load_sound("sound/poof.wav");
    let click = load_sound("sound/click.wav");

    let music_game = load_sound("sound/music.ogg");
    let music_menu = load_sound("sound/menu.ogg");

    let lose = load_sound("sound/lose.ogg");

    let whoosh = load_sound("sound/whoosh.wav");
    let chonk = load_sound("sound/chonk.wav");

    /// 0 for nothing
    /// 1 for menu
    /// 2 for game
    var play_music: int = 0;

    fun paper() {
        let sfx = paper_sfx[randi_range(0, paper_sfx.length)];
        play_sound_once(sfx);
    }

    fun game_music() {
        stop_sound(music_menu);
        stop_sound(music_game);
        if is_sound_loaded(music_game) {
            play_sound_once(music_game);
        }
        else {
            play_music = 2;
        }
    }

    fun menu_music() {
        stop_sound(music_menu);
        stop_sound(music_game);
        if is_sound_loaded(music_menu) {
            play_sound_once(music_menu);
        }
        else {
            play_music = 1;
        }
    }
    
    fun update() {
        if play_music == 2 {
            if is_sound_loaded(music_game) {
                play_sound_once(music_game);
                play_music = 0;
            }
        }
        if play_music == 1 {
            if is_sound_loaded(music_menu) {
                play_sound_looping(music_menu);
                play_music = 0;
            }
        }
    }
}

