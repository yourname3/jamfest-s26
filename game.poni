let REWARD_CARDS = [
    CARD_MOVE_4,
    CARD_FARM_LEFT,
    CARD_GAIN_APPLE_UP,
    CARD_GAIN_CARROT_DOWN,
];

fun up(tiles: int) {
    for i in 0..tiles {
        if horse.position.y > 0 {
            horse.position.y -= 256;
        }
    }
}
fun down(tiles: int) {
    for i in 0..tiles {
        if horse.position.y < 512 {
            horse.position.y += 256;
        }
    }
}
fun left(tiles: int) {
    horse.position.x -= 256;
}
fun right(tiles: int) {
    horse.position.x += 256;
}
fun gain_apples(count: int) {
    apples.count += count;
}
fun gain_carrots(count: int) {
    carrots.count += count;
}

class Textures {
    //let test = load_texture("tex/test.png");
    let card = load_texture("tex/card.png");
    let card_back = load_texture("tex/card_back.png");

    let carrot = load_texture("tex/carrot.png");
    let apple = load_texture("tex/apple.png");

    let arrow_right = load_texture("tex/arrow_right.png");
    let arrow_left  = load_texture("tex/arrow_left.png");
    let arrow_up    = load_texture("tex/arrow_up.png");
