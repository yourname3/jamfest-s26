fun up(tiles: int) {
    for i in 0..tiles { action_queue_push(ACTION_UP); }
    // for i in 0..tiles {
    //     if horse.position.y > 0 {
    //         horse.position.y -= 256;
    //     }
    // }
}
fun down(tiles: int) {
    for i in 0..tiles { action_queue_push(ACTION_DOWN); }
    // for i in 0..tiles {
    //     if horse.position.y < 512 {
    //         horse.position.y += 256;
    //     }
    // }
}
fun left(tiles: int) {
    for i in 0..tiles { action_queue_push(ACTION_LEFT); }
}
fun right(tiles: int) {
    for i in 0..tiles { action_queue_push(ACTION_RIGHT); }
}
fun gain_apples(count: int) {
    for i in 0..count { action_queue_push(ACTION_APPLE); }
    //apples.count += count;
}
fun gain_carrots(count: int) {
    for i in 0..count { action_queue_push(ACTION_CARROT); }
}
fun draw_cards(count: int) {
    for i in 0..count { action_queue_push(ACTION_DRAW); }
}

var current_scene: int = SCENE_MENU;

let SCENE_GAME: int = 0;
let SCENE_WIN : int = 1;
let SCENE_LOSE: int = 2;
let SCENE_MENU: int = 3;

class ActionQueueItem {
    let action: int;
    var next: ActionQueueItem?;
}

var action_queue: ActionQueueItem? = nil;
var action_queue_tail: ActionQueueItem? = nil;
var action_queue_push: fun(int) = fun(x: int) {};
var action_queue_pop: fun() -> ActionQueueItem? = fun() -> ActionQueueItem? { nil };

fun action_queue_push_impl(action: int) {
    let item = new ActionQueueItem {
        action: action,
        next: nil,
    };

    if action_queue_tail.is_some() {
        //print("Chain Action To Tail: ", action);
        action_queue_tail.or_panic().next = item;
        action_queue_tail = item;
    }
    else {
        //print("Rewrite Tail: ", action);
        action_queue_tail = item;
        //action_queue = item;
    }

    // If action_queue is pointing at the nil at the end,
    // it is now pointing at the new item.
    if action_queue.is_nil() {
        action_queue = item;
    }
}

fun action_queue_pop_impl() -> ActionQueueItem? {
    let item = action_queue;

    if action_queue.is_some() {
        action_queue = action_queue.or_panic().next;
    }

    item
}

