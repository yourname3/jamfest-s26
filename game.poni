        down(1);
    }
};

let CARD_GAIN_APPLE = new CardData {
    icon: tex.apple,

    callback: fun() { gain_apples(1); }
};

let CARD_GAIN_CARROT = new CardData {
    icon: tex.carrot,

    callback: fun() { gain_carrots(1); }
};

