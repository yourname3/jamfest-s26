};

let SIZE_CARD: vec2 = (256, 340);
let SIZE_ICON: vec2 = (256, 256);

let INITIAL_SCROLL_SPEED: float = 128 - 20;
let SCROLL_SPEED2 = INITIAL_SCROLL_SPEED + 30;
let SCROLL_SPEED3 = INITIAL_SCROLL_SPEED + 60;
let SCROLL_SPEED4 = INITIAL_SCROLL_SPEED + 90;
var current_scroll_speed: float = INITIAL_SCROLL_SPEED;

fun in_rect(point: vec2, rect_pos: vec2, rect_size: vec2) -> bool {
    if (point.x < rect_pos.x) or point.y < rect_pos.y {
        return false;
    }
    let rect_pos = rect_pos + rect_size;
    if (point.x > rect_pos.x) or point.y > rect_pos.y {
        return false;
    }

    true
}

var current_moved_card: Card? = nil;
var current_moved_card_offset: vec2 = (0, 0);

let STATE_NEW         : int = 0;
let STATE_DRAW_PILE   : int = 1;
let STATE_HAND        : int = 2;
let STATE_DISCARD_PILE: int = 3;
let STATE_DESTROYED   : int = 4;
let STATE_ON_TRACK    : int = 5;

let CARD_KIND_NORMAL : int = 0;
let CARD_KIND_CURSE  : int = 1;

var lane_position: float = 0.0;

let ACTION_RIGHT: int = 0;
let ACTION_LEFT : int = 1;
let ACTION_UP   : int = 2;
let ACTION_DOWN : int = 3;
let ACTION_APPLE: int = 4;
let ACTION_CARROT: int = 5;
let ACTION_DRAW:  int = 6;

let HORSE_STARTING_POS: vec2 = (screen_size.x / 2, 256);

class Horse {
    var position: vec2 = HORSE_STARTING_POS;

    var current_item: ActionQueueItem? = nil;
    var action_timer: float = -1.0;

    var lerp_start: vec2 = (0, 0);
    var lerp_end  : vec2 = (0, 0);

    fun update(delta: float) {
        position.x -= delta * current_scroll_speed;
        lerp_start.x -= delta * current_scroll_speed;
        lerp_end.x -= delta * current_scroll_speed;
        draw_texture(tex.horse, position, (#ffff));

        if current_item.is_nil() {
            current_item = action_queue;
            // if current_item.is_some() {
            //     print("Horse: Next Item: ", current_item.or_panic().action);
            // }
        }

        if current_item.is_some() {
            if action_timer < 0 {
                // Just started the action.
                action_timer = 1.0;

                lerp_start = position;
                lerp_end = position;

                let action = current_item.or_panic().action;
                if action == ACTION_RIGHT  { play_sound_once(sound.whoosh); lerp_end = position + ( 256, 0); }
                if action == ACTION_LEFT   { play_sound_once(sound.whoosh); lerp_end = position + (-256, 0); }
                if action == ACTION_UP     { play_sound_once(sound.whoosh); lerp_end = position + (0, -256); }
                if action == ACTION_DOWN   { play_sound_once(sound.whoosh); lerp_end = position + (0,  256); }
                if action == ACTION_APPLE  { play_sound_once(sound.pop); apples.scale = 1.4; apples.count  += 1; }
                if action == ACTION_CARROT { play_sound_once(sound.pop); carrots.scale = 1.4; carrots.count += 1; }
                if action == ACTION_DRAW   { draw_card(); }

                if lerp_end.y < 0 { lerp_end.y = 0; }
                if lerp_end.y > 512 { lerp_end.y = 512; }

                // Clamp to side of screen
                if lerp_end.x > screen_size.x {
                    lerp_end.x = lerp_start.x;
                }
            }
            else {
                action_timer -= delta * 10.0;

                let lerp_t = 1.0 - action_timer;
                position = lerp(lerp_start, lerp_end, lerp_t);

                if action_timer < 0 {
                    action_timer = -1.0;
                    action_queue_pop();
                    // Start the next item next frame.
                    current_item = action_queue;

                    position = lerp_end;
                }
            }
        }
    }
}

class CardData {
    let icon: Texture2D? = nil;
    let rows: Array[Array[Texture2D]] = [];
    let scale: float = 1.0;
    // Cost: negative for apples, positive for carrots? Or is that too jank?
    let cost: int = 0;

    let destroys_self: bool = false;

    /// 0 for normal
    /// 1 for curse
    let card_kind: int = 0;

    let callback: fun();
}

class Card {
    var position: vec2 = (0, 0);

    let data: CardData;

    /// Keep track of whether the card is:
    /// - New and available for selection
    /// - In the draw pile
    /// - In the hand
    /// - In the discard pile
    var state: int = 0;

    var hand_position: vec2 = (0, 0);

    var scale: float = 1.0;

    var may_add_card: bool = false;

    var alpha: float = 1.0;

    var was_highlight: bool = false;

    fun draw(highlight: bool, playable: bool) {
        gl_push_translation(position + SIZE_CARD * 0.5);
        gl_push_scale((1, 1) * scale);
        
        let pos = -SIZE_CARD * 0.5;
        let modulate = (#ffff);
        var modulate = if highlight { modulate } else { modulate * 0.95 };

        if may_add_card {
            modulate = (#ffff) * 0.85;
        }

        let icon = data.icon;
        let cost = data.cost;

        if (state == STATE_HAND) and not playable {
            modulate = (#ffff) * 0.7;
        }

        modulate *= alpha;

        if (state == STATE_DISCARD_PILE) or (state == STATE_DRAW_PILE) and (scale < 0.4) {
            draw_texture(tex.card_back, pos, modulate);
            gl_pop();
            gl_pop();
            return;
        }

        let card_tex = if data.card_kind == CARD_KIND_CURSE { tex.card_curse } else { tex.card };

        draw_texture(card_tex, pos, modulate);
        let icon_scale = 0.8;
        
        if icon.is_some() {
            let icon = icon.or_panic();
            
            draw_texture_rot_scale(icon, pos + (SIZE_CARD - SIZE_ICON * icon_scale) / 2, 0,
                icon_scale, modulate);
        }

        let center = pos + SIZE_CARD * 0.5;
        let step_size = SIZE_ICON * icon_scale * data.scale;
        let y = center.y - (data.rows.length * step_size.y / 2);
        for i in 0..data.rows.length {
            let row = data.rows[i];
            let x = (center.x - row.length * step_size.x / 2);
            
            let y = y + i * step_size.y;
            for j in 0..row.length {

                let x = x + j * step_size.x;

                draw_texture_rot_scale(row[j], (x, y), 0,
                    icon_scale * data.scale, modulate);
            }
        }

        if cost != 0 {
            let cost = if cost < 0 { (-cost, tex.apple) } else { (cost, tex.carrot) };

            draw_texture_rot_scale(cost.1, pos, 0, 0.2, modulate);
            draw_text_fonts(str(cost.0), FONT, pos + (60, 40),
                32.0, 1.2, FONT_COLOR);
        }

        gl_pop();
        gl_pop();
    }

    fun update(delta: float) {
        // Reset addibility
        var highlight = false;
        let mouse = screen.mouse();

        var playable = true;

        if data.cost != 0 {
            if data.cost < 0 {
                if apples.count < -data.cost {
                    playable = false;
                }
            }
            else {
                if carrots.count < data.cost {
                    playable = false;
                }
            }
        }

        var target_scale = 1.0;

        if (state == STATE_HAND) or (state == STATE_NEW) {
            highlight = current_moved_card.is_nil() and in_rect(mouse, position, SIZE_CARD);
        }

        if (current_scene != SCENE_GAME) {
            highlight = false;
        }

        if highlight { target_scale = 1.2; }

        if state == STATE_HAND {
            // if highlight and playable and is_mouse_button_down(MOUSE_LEFT) {
            //     current_moved_card = self;
            //     current_moved_card_offset = position - mouse;
            // }
            position += (hand_position - position) * 0.1;

            // if current_moved_card == self {
            //     let playable = playable and (position.y < screen_size.y / 2);
            //     if not is_mouse_button_down(MOUSE_LEFT) {
            //         current_moved_card = nil;
            //         if playable {
            //             hand.play_card(self);
            //         }
            //     }
            //     else {
            //         position = mouse + current_moved_card_offset;
            //     }

            //     if playable {
            //         target_scale = 0.7;
            //     }
            // }
            // else {
            //     position += (hand_position - position) * 0.8;
            // }
            if highlight and playable and is_mouse_button_pressed(MOUSE_LEFT) {
                hand.play_card(self);
                //may_add_card = true;
            }

            // if not highlight {
            //     may_add_card = false;
            // }

            // if may_add_card and playable and not is_mouse_button_down(MOUSE_LEFT) {
            //     hand.play_card(self);
            //     may_add_card = false;
            // }

            // if may_add_card {
            //     target_scale *= 0.93;
            // }
        }

        if state == STATE_ON_TRACK {
            position.x -= current_scroll_speed * delta;

            target_scale = 0.7;

            let size = SIZE_CARD * target_scale;
            let center = position + SIZE_CARD * 0.5;
            let corner = center - size * 0.5;

            if in_rect(horse.position + SIZE_ICON * 0.5, corner, size) {
                play_sound_once(sound.chonk);
                pile_discard.add(self);
            }
        }

        if state == STATE_NEW {
            position.x -= current_scroll_speed * delta;

            target_scale *= 0.5;
   
            if highlight and is_mouse_button_down(MOUSE_LEFT) {
                may_add_card = true;
            }

            if not highlight {
                may_add_card = false;
            }

            if may_add_card and not is_mouse_button_down(MOUSE_LEFT) {
                // I think we want new cards to go in the discard pile?
                pile_discard.add(self);
                may_add_card = false;
            }

            if may_add_card {
                target_scale *= 0.93;
            }
        }

        let DISCARD_PILE_POS: vec2 = (screen_size.x - SIZE_CARD.x, (screen_size.y / 2) + 100);
        let DRAW_PILE_POS: vec2    = (0,                           (screen_size.y / 2) + 100);
       //let DESTROYED_POS: vec2    = (screen_size.x + SIZE_CARD.x * 2, (screen_size.y / 2));
        let DESTROYED_POS: vec2 = (screen_size.x / 2, -400);

        if state == STATE_DISCARD_PILE {
            target_scale = 0.2;
            position += (DISCARD_PILE_POS - position) * 0.1;
        }

        if state == STATE_DRAW_PILE {
            target_scale = 0.2;
            position += (DRAW_PILE_POS - position) * 0.1;
        }

        if state == STATE_DESTROYED {
            target_scale = 0.7;
            position += (DESTROYED_POS - position) * 0.002;

            alpha -= delta * 4.0;
            if alpha < 0 { alpha = 0; }
        }

        scale += (target_scale - scale) * 0.1;

        if (state == STATE_DRAW_PILE) or (state == STATE_DISCARD_PILE) {
            draw(highlight, playable);
        }
        else {
            draw(highlight, playable);
        }

        if highlight and not was_highlight {
            sound.paper();
        }
        was_highlight = highlight;
    }
}

