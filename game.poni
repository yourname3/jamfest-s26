// Spawns cards off-screen.
fun spawn_rewards() {
    let good_card_idx = randi_range(0, 4);
    for i in 0..4 {
        let i : float = i;

        let data = if i == good_card_idx { IMPORTANT_REWARD_CARDS[randi_range(0, IMPORTANT_REWARD_CARDS.length)] }
            else { REWARD_CARDS[randi_range(0, REWARD_CARDS.length)]; };

        var card = new Card {
            data: data,
            state: STATE_NEW,
            position: (screen_size.x + 0.25 * i * screen_size.x, screen_size.y / 3) + (SIZE_CARD * 0.5)
        };

        ALL_CARDS.push(card);
    }

    for i in 0..8 {
        if randi_range(0, 2) == 0 { continue; }

        let i: float = i;

        let data = CURSE_CARDS[randi_range(0, CURSE_CARDS.length)];

        let y = randi_range(0, 3);

        let corner: vec2 = (screen_size.x + 256 * i, y * 256);
        let pos = corner + (128, 128) - SIZE_CARD * 0.5;

        let card = new Card {
            data: data,
            state: STATE_ON_TRACK,
            position: pos,
        };

        ALL_CARDS.push(card);
    }
}

fun update_lanes(dt: float) {
    lane_position -= dt * current_scroll_speed;
    draw_texture(tex.lanes, (lane_position, 0), (#ffff));
    draw_texture(tex.lanes, (lane_position + screen_size.x, 0), (#ffff));

    while lane_position < -screen_size.x {
        lane_position += screen_size.x;

        spawn_rewards();
    }
}

class FruitCounter {
    var count: int = 0;

    let texture: Texture2D;
    var position: vec2;

    var scale = 1.0;

    fun update() {
        scale += (1.0 - scale) * 0.01;

        let center = position + SIZE_ICON * 0.5 * 0.5;
        let corner = center - SIZE_ICON * 0.5 * 0.5 * scale;

        draw_texture_rot_scale(texture, corner, 0, 0.5 * scale, (#ffff));

        let text = str(count);
        let dims = measure_text_fonts(text, FONT, 64, 2);
        let dims = (dims.x, dims.y);

        draw_text_fonts(text, FONT, position + (256 * 0.5, dims.y), 64, 2, (#535353ff));
    }
}

let MAIN_TIMER_INIT: float = 120.0;
/// Main timer for winning the game
var main_timer: float = MAIN_TIMER_INIT;

fun update_dt(dt: float) {
    if not has_initialized {
        draw_card_fn = draw_card;
        action_queue_pop = action_queue_pop_impl;
        action_queue_push = action_queue_push_impl;
        restart_game = restart_game_impl;

        initialize();
        sound.menu_music();
        has_initialized = true;
    }

    sound.update();

    if current_scene == SCENE_MENU {
        draw_texture(tex.menu, (0, 0), (#ffff));
        play_button.pos = (1500, 300);
        play_button.update(dt);
        draw_text_fonts("Horse Race Time", FONT, (1200, 200), 64, 2, (#1c1c1cff));
        return;
    }

    draw_texture(tex.bg, (0, 0), (#ffff));

    update_lanes(dt);

    horse.update(dt);

    hand.update();

    apples.update();
    carrots.update();

    //apples.position.x = carrots.position.x = 1800;
    apples.position = (20, screen_size.y - 128 - 20);
    carrots.position = (20 + 400, screen_size.y - 128 - 20);

    for i in 0..ALL_CARDS.length {
        //cards[i].position = (20, 20) + (i * (SIZE_CARD.x + 20), 0);
        ALL_CARDS[i].update(dt);
    }

    end_turn_button.update(dt);

    // Increase speed by 2 every 10 seconds
    //current_scroll_speed += 2 * dt / 10;

    if current_scroll_speed > 512 {
        current_scroll_speed = 512;
    }

    // Lose when you're far off the screen.
    if horse.position.x < -256 {
        if current_scene != SCENE_LOSE {
            stop_sound(sound.music_menu);
            stop_sound(sound.music_game);
            play_sound_once(sound.lose);
        }
        current_scene = SCENE_LOSE;
        current_scroll_speed = 0;
    }

    if current_scene == SCENE_LOSE {
        draw_text_fonts("You Lose :(", FONT, (770, 650), 64, 2, (#1c1c1cff));
        
        play_again_button.pos = (920, 700);
        //draw_text_fonts("Play Again", FONT, (920, 750), 64, 1, (#1c1c1cff));

        play_again_button.update(dt);
    }

    if current_scene == SCENE_WIN {
        draw_text_fonts("You Win :)", FONT, (770, 650), 64, 2, (#1c1c1cff));
        
        play_again_button.pos = (920, 700);
        current_scroll_speed = 0;
        //draw_text_fonts("Play Again", FONT, (920, 750), 64, 1, (#1c1c1cff));

        play_again_button.update(dt);
    }

    if current_scene == SCENE_GAME {
        main_timer -= dt;
        if main_timer < 0 {
            main_timer = 0;
            current_scene = SCENE_WIN;
        }

        if main_timer < 90 and current_scroll_speed < SCROLL_SPEED2 {
            current_scroll_speed = SCROLL_SPEED2;
        }
        if main_timer < 60 and current_scroll_speed < SCROLL_SPEED3 {
            current_scroll_speed = SCROLL_SPEED3;
        }
        if main_timer < 30 and current_scroll_speed < SCROLL_SPEED4 {
            current_scroll_speed = SCROLL_SPEED4;
        }
    }

    let minutes = floor(main_timer / 60);
    let seconds = floor(main_timer - (minutes * 60));
    let hundredths = floor((main_timer - (minutes * 60) - seconds) * 100);

    let minutes = str(minutes);

    var seconds = str(seconds);
    while seconds.length < 2 {
        seconds = str("0", seconds);
    }
    var hundredths = str(hundredths);
    while hundredths.length < 2 {
        hundredths = str("0", hundredths);
    }

    let time = str(minutes, ":", seconds, ".", hundredths);
    draw_text_fonts(time, FONT, (1780, 1350), 32, 2, (#232323ff));
}