}

let FONT = load_font("font/Oswald-Regular.ttf");
let FONT_COLOR = (#342f28ff);

let screen_size = (256 * 8, 256 * 6);

let tex = new Textures{};

let screen = new Screen {
    target_size: screen_size,
    target_offset: -screen_size / 2,
};

let SIZE_CARD: vec2 = (256, 340);
let SIZE_ICON: vec2 = (256, 256);

var current_scroll_speed: float = 128;

fun in_rect(point: vec2, rect_pos: vec2, rect_size: vec2) -> bool {
    if (point.x < rect_pos.x) or point.y < rect_pos.y {
        return false;
    }
    let rect_pos = rect_pos + rect_size;
    if (point.x > rect_pos.x) or point.y > rect_pos.y {
        return false;
    }

    true
}

var current_moved_card: Card? = nil;
var current_moved_card_offset: vec2 = (0, 0);

let STATE_NEW         : int = 0;
let STATE_DRAW_PILE   : int = 1;
let STATE_HAND        : int = 2;
let STATE_DISCARD_PILE: int = 3;

var lane_position: float = 0.0;

class Horse {
    var position: vec2 = (screen_size.x / 2, 0);

    fun update(delta: float) {
        position.x -= delta * current_scroll_speed;
        draw_texture(tex.horse, position, (#ffff));
    }
}

class CardData {
    let icon: Texture2D? = nil;
    let rows: Array[Array[Texture2D]] = [];
    let scale: float = 1.0;
    // Cost: negative for apples, positive for carrots? Or is that too jank?
    let cost: int = 0;

    let callback: fun();
}

class Card {
    var position: vec2 = (0, 0);

    let data: CardData;

    /// Keep track of whether the card is:
    /// - New and available for selection
    /// - In the draw pile
    /// - In the hand
    /// - In the discard pile
    var state: int = 0;

    var hand_position: vec2 = (0, 0);

    var scale: float = 1.0;

    var may_add_card: bool = false;

    fun draw(highlight: bool, playable: bool) {
        gl_push_translation(position + SIZE_CARD * 0.5);
        gl_push_scale((1, 1) * scale);
        
        let pos = -SIZE_CARD * 0.5;
        let modulate = (#ffff);
        var modulate = if highlight { modulate } else { modulate * 0.95 };

        if may_add_card {
            modulate = (#ffff) * 0.85;
        }

        let icon = data.icon;
        let cost = data.cost;

        if (state == STATE_HAND) and not playable {
            modulate = (#ffff) * 0.7;
        }

        if (state == STATE_DISCARD_PILE) or (state == STATE_DRAW_PILE) and (scale < 0.4) {
            draw_texture(tex.card_back, pos, modulate);
            gl_pop();
            gl_pop();
            return;
        }

        draw_texture(tex.card, pos, modulate);
        let icon_scale = 0.8;
        
        if icon.is_some() {
            let icon = icon.or_panic();
            
            draw_texture_rot_scale(icon, pos + (SIZE_CARD - SIZE_ICON * icon_scale) / 2, 0,
                icon_scale, modulate);
        }

        let center = pos + SIZE_CARD * 0.5;
        let step_size = SIZE_ICON * icon_scale * data.scale;
        let y = center.y - (data.rows.length * step_size.y / 2);
        for i in 0..data.rows.length {
            let row = data.rows[i];
            let x = (center.x - row.length * step_size.x / 2);
            
            let y = y + i * step_size.y;
            for j in 0..row.length {

                let x = x + j * step_size.x;

                draw_texture_rot_scale(row[j], (x, y), 0,
                    icon_scale * data.scale, modulate);
            }
        }

        if cost != 0 {
            let cost = if cost < 0 { (cost, tex.apple) } else { (cost, tex.carrot) };

            draw_texture_rot_scale(cost.1, pos, 0, 0.2, modulate);
            draw_text_fonts("3", FONT, pos + (60, 40),
                32.0, 1.2, FONT_COLOR);
        }

        gl_pop();
        gl_pop();
    }

    fun update(delta: float) {
        // Reset addibility
        var highlight = false;
        let mouse = screen.mouse();

        var playable = true;

        if data.cost != 0 {
            if data.cost < 0 {
                if apples.count < -data.cost {
                    playable = false;
                }
            }
            else {
                if carrots.count < data.cost {
                    playable = false;
                }
            }
        }

        var target_scale = 1.0;

        if (state == STATE_HAND) or (state == STATE_NEW) {
            highlight = current_moved_card.is_nil() and in_rect(mouse, position, SIZE_CARD);
        }

        if highlight { target_scale = 1.2; }

        if state == STATE_HAND {
            if highlight and playable and is_mouse_button_down(MOUSE_LEFT) {
                current_moved_card = self;
                current_moved_card_offset = position - mouse;
            }

            if current_moved_card == self {
                let playable = playable and (position.y < screen_size.y / 2);
                if not is_mouse_button_down(MOUSE_LEFT) {
                    current_moved_card = nil;
                    if playable {
                        hand.play_card(self);
                    }
                }
                else {
                    position = mouse + current_moved_card_offset;
                }

                if playable {
                    target_scale = 0.7;
                }
            }
            else {
                position += (hand_position - position) * 0.8;
            }
        }

        if state == STATE_NEW {
            position.x -= current_scroll_speed * delta;

            target_scale *= 0.5;
   
            if highlight and is_mouse_button_down(MOUSE_LEFT) {
                may_add_card = true;
            }

            if not highlight {
                may_add_card = false;
            }

            if may_add_card and not is_mouse_button_down(MOUSE_LEFT) {
                // I think we want new cards to go in the discard pile?
                pile_discard.add(self);
                may_add_card = false;
            }

            if may_add_card {
                target_scale *= 0.93;
            }
        }

        let DISCARD_PILE_POS: vec2 = (screen_size.x - SIZE_CARD.x, (screen_size.y / 2) + 100);
        let DRAW_PILE_POS: vec2    = (0,                           (screen_size.y / 2) + 100);

        if state == STATE_DISCARD_PILE {
            target_scale = 0.2;
            position += (DISCARD_PILE_POS - position) * 0.1;
        }

        if state == STATE_DRAW_PILE {
            target_scale = 0.2;
            position += (DRAW_PILE_POS - position) * 0.1;
        }

        scale += (target_scale - scale) * 0.1;

        if (state == STATE_DRAW_PILE) or (state == STATE_DISCARD_PILE) {
            draw(highlight, playable);
        }
        else {
            draw(highlight, playable);
        }
    }
}

let apples = new FruitCounter {
    texture: tex.apple,
    position: (1000, 1000)
};
let carrots = new FruitCounter {
    texture: tex.carrot,
    position: (1000, 1200)
};

let ALL_CARDS: DynArray[Card] = [
    new Card { data: CARD_MOVE_RIGHT  },
    new Card { data: CARD_MOVE_UP     },
    new Card { data: CARD_MOVE_DOWN   },
    new Card { data: CARD_GAIN_APPLE  },
    new Card { data: CARD_GAIN_CARROT },

    new Card { data: CARD_MOVE_RIGHT  },
    new Card { data: CARD_MOVE_UP     },
    new Card { data: CARD_MOVE_DOWN   },
    new Card { data: CARD_GAIN_APPLE  },
    new Card { data: CARD_GAIN_CARROT },
];

class Pile {
    var cards: DynArray[Card] = [];
    let state: int;

    fun add(card: Card) {
        cards.push(card);
        card.state = state;
    }

    /// Returns whether the card was located in the array.
    fun remove(card: Card) -> bool {
        var new_cards: DynArray[Card] = [];
        var located: bool = false;

        for i in 0..cards.length {
            if cards[i] == card {
                located = true;
            }
            else {
                new_cards.push(cards[i]);
            }
        }

        cards = new_cards;
        located
    }

    fun swap(i: int, j: int) {
        let tmp = cards[i];
        cards[i] = cards[j];
        cards[j] = tmp;
    }

    fun shuffle() {
        for i in 0..=cards.length - 2 {
            let j = randi_range(i, cards.length - 1);
            swap(i, j)
        }
    }
}

let pile_draw = new Pile { state: STATE_DRAW_PILE };
let pile_discard = new Pile { state: STATE_DISCARD_PILE };
let pile_hand = new Pile { state: STATE_HAND };

fun apply_costs(card: Card) {
    if card.data.cost < 0 {
        apples.count += card.data.cost;
    }
    if card.data.cost > 0 {
        carrots.count -= card.data.cost;
    }
}

/// Keeps track of the hand of cards
class Hand {
    fun add_card(card: Card) {
        pile_hand.add(card);
    }

    fun play_card(card: Card) {
        if pile_hand.remove(card) {
            apply_costs(card);
            card.data.callback();
            pile_discard.add(card);
        }
    }

    fun discard_card(card: Card) {
        if pile_hand.remove(card) {
            pile_discard.add(card);
        }
    }

    fun update() {
        let cards = pile_hand.cards;

        let screen_center = screen_size.x / 2;
        let width = cards.length * SIZE_CARD.x + (cards.length - 1) * 20;

        let start_x = screen_center - width * 0.5;
        let increment: float = SIZE_CARD.x + 20;

        for i in 0..cards.length {
            let card = cards[i];

            card.hand_position = (start_x + increment * i, 1000);
        }
    }
}

fun shuffle_discard_into_draw() {
    for i in 0..pile_discard.cards.length {
        let card = pile_discard.cards[i];
        pile_draw.cards.push(card);
        card.state = STATE_DRAW_PILE;
    }
    pile_discard.cards = [];

    pile_draw.shuffle();

    // while pile_discard.cards.length > 0 {
    //     let card = pile_discard.cards[0];
    //     pile_discard.remove(card);
    //     pile_draw.add(card);
    // }

    // TODO: Randomize the order.
}

fun draw_card() {
    fun get_card() -> Card? {
        if pile_draw.cards.length > 0 {
            return pile_draw.cards.pop_or_panic();
        }

        // No cards in draw pile, shuffle the discard pile into the draw pile.
        shuffle_discard_into_draw();

        if pile_draw.cards.length > 0 {
            return pile_draw.cards.pop_or_panic();
        }

        nil
    }

    let card = get_card();
    let card = card else return;

    // We already removed the card from pile_draw using pop_or_panic().
    hand.add_card(card);
}

fun rollover_turn() {
    while pile_hand.cards.length > 0 {
        hand.discard_card(pile_hand.cards[0]);
    }

    for i in 0..5 {
        draw_card();
    }
}

class EndTurnButton {
    var energy = 0.0;
    var pressed = false;
    var scale = 1.0;

    fun update(dt: float) {
        let pos = (screen_size.x - 300, 1400);

        let SIZE = 32;
        let SCALE = 2;

        let text_dim = measure_text_fonts("End Turn", FONT, SIZE, SCALE);

        let rpos = pos - (16, 16);
        let rsize = (text_dim.x, text_dim.y) + (32, 32);

        var target_scale = 1.0;

        var highlight = false;
        if energy < 1 {
            energy += dt;
            highlight = false;
            pressed = false;
        }
        else {
            let mouse = screen.mouse();
            highlight = in_rect(mouse, rpos, rsize);

            if not highlight { pressed = false; }

            if highlight and is_mouse_button_down(MOUSE_LEFT) {
                pressed = true;
            }

            if pressed and is_mouse_button_released(MOUSE_LEFT) {
                pressed = false;
                energy = 0;
                
                rollover_turn();
            }
        }

        if highlight { target_scale = 1.2; }
        if pressed   { target_scale = 0.8; }

        scale += (target_scale - scale) * 0.1;

        gl_push_translation(rpos + rsize * 0.5);
        gl_push_scale((1, 1) * scale);

        let offset = -rsize * 0.5;

        draw_rectangle(offset , rsize, (#3e3e3eff));
        draw_rectangle(offset + (16, 16), rsize - 32, (#2c2c2cff));
        draw_rectangle(offset , (rsize.x * energy, rsize.y), if highlight { (#b39883ff) } else { (#a38a76ff) });
        draw_text_fonts("End Turn", FONT, offset + (16, 16) + (0, text_dim.y), SIZE, SCALE, (#372f26ff));

        gl_pop();
        gl_pop();
    }
}

let hand = new Hand{};
let horse = new Horse{};
let end_turn_button = new EndTurnButton{};

var has_initialized = false;

fun initialize() {
    // for card in 0..ALL_CARDS.length {
    //     pile_hand.cards.push(ALL_CARDS[card]);
    //     ALL_CARDS[card].state = STATE_HAND;
    // }

    for i in 0..ALL_CARDS.length {
        pile_draw.add(ALL_CARDS[i]);
    }

    pile_draw.shuffle();
    for i in 0..5 {
        draw_card();
    }

    // ALL_CARDS.push(new Card {
    //     data: CARD_MOVE_RIGHT,
    //     state: STATE_NEW,
    //     position: (screen_size.x, screen_size.y / 3) + (SIZE_CARD * 0.5),
    // });
    spawn_rewards();
}

// Spawns cards off-screen.
fun spawn_rewards() {
    for i in 0..4 {
        let i : float = i;

        let data = REWARD_CARDS[randi_range(0, REWARD_CARDS.length)];

        var card = new Card {
            data: data,
            state: STATE_NEW,
            position: (screen_size.x + 0.25 * i * screen_size.x, screen_size.y / 3) + (SIZE_CARD * 0.5)
        };

        ALL_CARDS.push(card);
    }
}

fun update_lanes(dt: float) {
    lane_position -= dt * current_scroll_speed;
    draw_texture(tex.lanes, (lane_position, 0), (#ffff));
    draw_texture(tex.lanes, (lane_position + screen_size.x, 0), (#ffff));

    while lane_position < -screen_size.x {
        lane_position += screen_size.x;

        spawn_rewards();
    }
}

class FruitCounter {
    var count: int = 0;

    let texture: Texture2D;
    var position: vec2;

    fun update() {
        draw_texture_rot_scale(texture, position, 0, 0.5, (#ffff));

        let text = str(count);
        let dims = measure_text_fonts(text, FONT, 64, 2);
        let dims = (dims.x, dims.y);

        draw_text_fonts(text, FONT, position + (256 * 0.5, dims.y), 64, 2, (#535353ff));
    }
}

fun update_dt(dt: float) {
    if not has_initialized {
        initialize();
        has_initialized = true;
    }

    update_lanes(dt);

    horse.update(dt);

    hand.update();

    apples.update();
    carrots.update();

    //apples.position.x = carrots.position.x = 1800;
    apples.position = (20, screen_size.y - 128 - 20);
    carrots.position = (20 + 400, screen_size.y - 128 - 20);

    for i in 0..ALL_CARDS.length {
        //cards[i].position = (20, 20) + (i * (SIZE_CARD.x + 20), 0);
        ALL_CARDS[i].update(dt);
    }

    end_turn_button.update(dt);

    // Increase speed by 2 every 10 seconds
    current_scroll_speed += 2 * dt / 10;

    if current_scroll_speed > 512 {
        current_scroll_speed = 512;
    }

    //print("hand: ", pile_hand.cards.length, " draw: ", pile_draw.cards.length, " discard: ", pile_discard.cards.length);
}