    CARD_MOVE_DOWN  ,
    CARD_GAIN_APPLE ,
    CARD_GAIN_CARROT,
];

var ALL_CARDS: DynArray[Card] = [];

class Pile {
    var cards: DynArray[Card] = [];
    let state: int;

    fun add(card: Card) {
        cards.push(card);
        card.state = state;
    }

    /// Returns whether the card was located in the array.
    fun remove(card: Card) -> bool {
        var new_cards: DynArray[Card] = [];
        var located: bool = false;

        for i in 0..cards.length {
            if cards[i] == card {
                located = true;
            }
            else {
                new_cards.push(cards[i]);
            }
        }

        cards = new_cards;
        located
    }

    fun swap(i: int, j: int) {
        let tmp = cards[i];
        cards[i] = cards[j];
        cards[j] = tmp;
    }

    fun shuffle() {
        for i in 0..=cards.length - 2 {
            let j = randi_range(i, cards.length - 1);
            swap(i, j)
        }
    }
}

let pile_draw = new Pile { state: STATE_DRAW_PILE };
let pile_discard = new Pile { state: STATE_DISCARD_PILE };
let pile_hand = new Pile { state: STATE_HAND };

fun apply_costs(card: Card) {
    if card.data.cost < 0 {
        apples.count += card.data.cost;
    }
    if card.data.cost > 0 {
        carrots.count -= card.data.cost;
    }
}

/// Keeps track of the hand of cards
class Hand {
    fun add_card(card: Card) {
        pile_hand.add(card);
    }

    fun play_card(card: Card) {
        if pile_hand.remove(card) {
            apply_costs(card);
            card.data.callback();
            if card.data.destroys_self {
                play_sound_once(sound.poof);
                card.state = STATE_DESTROYED;
            }
            else {
                play_sound_once(sound.click);
                pile_discard.add(card);
            }

            // Rearrange cards when we have a lot.
            if pile_hand.cards.length >= 6 {
                update_card_hand_pos();
            }
        }
    }

    fun discard_card(card: Card) {
        if pile_hand.remove(card) {
            pile_discard.add(card);
        }
    }

    fun update() {



    }

    fun update_card_hand_pos() {
        let cards = pile_hand.cards;

        let screen_center = screen_size.x / 2;
        let width = cards.length * SIZE_CARD.x + (cards.length - 1) * 20;

        let start_x = screen_center - width * 0.5;
        let increment: float = SIZE_CARD.x + 20;

        let cards = pile_hand.cards;

        for i in 0..cards.length {
            let card = cards[i];

            card.hand_position = (start_x + increment * i, 1000);
        }
    }
}

fun shuffle_discard_into_draw() {
    for i in 0..pile_discard.cards.length {
        let card = pile_discard.cards[i];
        pile_draw.cards.push(card);
        card.state = STATE_DRAW_PILE;
    }
    pile_discard.cards = [];

    pile_draw.shuffle();

    // while pile_discard.cards.length > 0 {
    //     let card = pile_discard.cards[0];
    //     pile_discard.remove(card);
    //     pile_draw.add(card);
    // }

    // TODO: Randomize the order.
}

fun draw_card() {
    fun get_card() -> Card? {
        if pile_draw.cards.length > 0 {
            return pile_draw.cards.pop_or_panic();
        }

        // No cards in draw pile, shuffle the discard pile into the draw pile.
        shuffle_discard_into_draw();

        if pile_draw.cards.length > 0 {
            return pile_draw.cards.pop_or_panic();
        }

        nil
    }

    let card = get_card();
    let card = card else return;

    sound.paper();

    // We already removed the card from pile_draw using pop_or_panic().
    hand.add_card(card);

    hand.update_card_hand_pos();
}

fun rollover_turn() {
    while pile_hand.cards.length > 0 {
        hand.discard_card(pile_hand.cards[0]);
    }

    // Do this as queued actions
    draw_cards(5);
    // for i in 0..5 {
    //     draw_card();
    // }
}

class Button {
    var pressed = false;
    var scale = 1.0;

    // BUG: This doesn't work without the :vec2
    var pos: vec2 = (0.0, 0.0);

    let text: StrBuf = "Play Again";

    var rect_color: vec4;
    var rect_color_highlight: vec4;
    var text_color: vec4;

    let callback: fun();

    fun update(dt: float) {
        let SIZE = 64;
        let SCALE = 1;

        let text_dim = measure_text_fonts(text, FONT, SIZE, SCALE);

        let rpos = pos - (16, 16);
        let rsize = (text_dim.x, text_dim.y) + (32, 32);

        var target_scale = 1.0;

        var highlight = false;

        let mouse = screen.mouse();
        highlight = in_rect(mouse, rpos, rsize);

        if not highlight { pressed = false; }

        if highlight and is_mouse_button_down(MOUSE_LEFT) {
            pressed = true;
        }

        if pressed and is_mouse_button_released(MOUSE_LEFT) {
            pressed = false;
            
            callback();
        }

        if highlight { target_scale = 1.2; }
        if pressed   { target_scale = 0.8; }

        scale += (target_scale - scale) * 0.1;

        gl_push_translation(rpos + rsize * 0.5);
        gl_push_scale((1, 1) * scale);

        let offset = -rsize * 0.5;

        draw_rectangle(offset , (rsize.x, rsize.y), if highlight { rect_color_highlight } else { rect_color });
        draw_text_fonts(text, FONT, offset + (16, 16) + (0, text_dim.y), SIZE, SCALE, text_color);

        gl_pop();
        gl_pop();
    }
}

var restart_game: fun() = fun(){print("OOPS!!!")};
fun restart_game_impl() {
    //print("RESTART GAME!!!!!");
    pile_draw.cards    = [];
    pile_discard.cards = [];
    pile_hand.cards    = [];

    ALL_CARDS = [];
    for i in 0..STARTING_DECK.length {
        ALL_CARDS.push(new Card { data: STARTING_DECK[i] });
    }

    for i in 0..ALL_CARDS.length {
        pile_draw.add(ALL_CARDS[i]);
    }

    pile_draw.shuffle();
    for i in 0..5 {
        draw_card();
    }

    spawn_rewards();

    horse.position = HORSE_STARTING_POS;
    lane_position = 0;
    carrots.count = 0;
    apples.count = 0;

    current_scene = SCENE_GAME;
    current_scroll_speed = INITIAL_SCROLL_SPEED;

    action_queue_tail = nil;
    action_queue = nil;

    horse.current_item = nil;
    horse.lerp_end = horse.position;
    horse.lerp_start = horse.position;
    horse.action_timer = -1;

    sound.game_music();

    main_timer = MAIN_TIMER_INIT;
}

let play_again_button = new Button {
    rect_color: (#b6b6b6ff),
    rect_color_highlight: (#c6c6c6ff),
    text_color: (#1c1c1cff),

    text: "Play Again",
    pos: (920, 700),

    callback: fun() {
        restart_game();
    },
};

